# Telegram API credentials — obtain from https://my.telegram.org/apps
API_ID=0
API_HASH=

# Session storage
SESSION_NAME=ukrgram
SESSION_DIR=./sessions

# Optional: pre-fill phone in international format, e.g. +380XXXXXXXXX
PHONE=

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Automation
AUTO_REPLY_TEXT=Automated reply from UkrGram. I will get back to you soon.
# Comma-separated keywords to log on incoming messages, e.g. urgent,invoice
NOTIFY_KEYWORDS=
